{
  "name": "trust-assertion-drift-monitor",
  "version": "0.1.0",
  "description": "Board-ready executive intelligence surface for tracking where public trust assertions drift away from live evidence, review freshness, owner accountability, and buyer-safe proof posture.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/trust-assertion-drift-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/mizcausevic-dev/trust-assertion-drift-monitor/issues"
  },
  "homepage": "https://github.com/mizcausevic-dev/trust-assertion-drift-monitor#readme",
  "keywords": [
    "trust-assertion-drift-monitor",
    "executive-intelligence",
    "trust-assertions",
    "board-intelligence",
    "trust-drift",
    "evidence-freshness",
    "buyer-readiness",
    "typescript"
  ],
  "bin": {
    "trust-assertion-drift-monitor": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "fixtures": "tsx scripts/generate_fixtures.ts",
    "prerender": "tsx scripts/prerender.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx scripts/run_demo.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run fixtures && npm run demo && npm run smoke",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.17.0",
    "globals": "^16.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.18.0",
    "vitest": "^4.1.8"
  }
}
